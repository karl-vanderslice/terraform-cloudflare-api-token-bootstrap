# Local Terraform working directory
.terraform/

# Keep lock file committed even if globally ignored.
!flake.lock

# Terraform state and crash artifacts
terraform.tfstate
terraform.tfstate.*
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Local variable definitions (often contain secrets)
terraform.tfvars
*.auto.tfvars
*.auto.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config and local environment files
.terraformrc
terraform.rc
.env
.env.*
.direnv/
!.envrc

# Tooling caches
.pre-commit-cache/

# Editor/OS noise
.DS_Store
.idea/
.vscode/
