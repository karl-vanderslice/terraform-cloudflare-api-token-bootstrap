# Local Terraform working directory
.terraform/

# Terraform state and crash artifacts
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Local variable definitions (often contain secrets)
terraform.tfvars
*.auto.tfvars
*.auto.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config and local environment files
.terraformrc
terraform.rc
.env
.env.*
.direnv/

# Tooling caches
.pre-commit-cache/

# Editor/OS noise
.DS_Store
.idea/
.vscode/
